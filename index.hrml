40.875 268.525 40.3465C267.989 39.8187 267.567 39.1895 267.287 38.4972C267.006 37.8049 266.871 37.0638 266.891 36.319C266.872 35.5737 267.006 34.8324 267.287 34.1396C267.568 33.4469 267.989 32.8173 268.525 32.2888C269.049 31.7631 269.679 31.3495 270.374 31.0737C271.069 30.798 271.815 30.6661 272.564 30.6863C273.308 30.6638 274.048 30.7948 274.737 31.0709C275.426 31.3469 276.048 31.7618 276.563 32.2888C277.435 33.1737 277.976 34.3221 278.098 35.5471C278.12 35.7314 278.134 35.9183 278.139 36.1106C278.142 36.1801 278.142 36.2495 278.142 36.319Z" fill="white"/><path d="M300.518 25.0655H300.496C300.312 25.0547 300.132 25.0492 299.957 25.0492C298.769 25.046 297.593 25.2854 296.504 25.7521C295.415 26.2189 294.437 26.9029 293.632 27.7606V25.0492H287.858V47.6188H293.632V35.2684C293.632 34.0647 294.119 32.9102 294.986 32.059C295.854 31.2078 297.031 30.7296 298.258 30.7296C298.697 30.7513 299.825 31.1417 300.203 31.3315C300.56 31.5538 301.516 32.3644 301.85 32.8906C302.146 33.4355 302.503 34.8559 302.549 35.2928V47.6188H308.552V33.4844C308.552 31.3428 307.722 29.2815 306.23 27.7182C304.738 26.1549 302.696 25.2066 300.518 25.0655Z" fill="white"/><path d="M328.784 30.5389V24.9947H322.989V17.8486H317.205V24.9947H312.312V30.5389H317.191V41.0164C317.192 42.7564 317.897 44.4248 319.151 45.6549C320.406 46.885 322.106 47.576 323.88 47.576H328.784V41.9042H325.103C324.823 41.9042 324.546 41.8501 324.288 41.745C324.03 41.6399 323.795 41.4859 323.597 41.2917C323.4 41.0976 323.243 40.8671 323.136 40.6134C323.029 40.3598 322.975 40.088 322.975 39.8136V30.5389H328.784Z" fill="white"/></svg>`;

function loadLogoImage() {
  return new Promise(resolve => {
    const blob = new Blob([LOGO_SVG], { type: 'image/svg+xml' });
    const url  = URL.createObjectURL(blob);
    const img  = new Image();
    img.onload  = () => { logoImg = img; URL.revokeObjectURL(url); resolve(); };
    img.onerror = () => resolve();
    img.src = url;
  });
}

function loadImage(url) {
  return new Promise(resolve => {
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload  = () => resolve(img);
    img.onerror = () => resolve(null);
    img.src = url;
  });
}

// ─── Search ────────────────────────────────────────────────────────────────
async function searchImages() {
  const q      = document.getElementById('search-q').value.trim();
  const status = document.getElementById('search-status');
  const grid   = document.getElementById('results');

  if (!q) { status.textContent = 'Enter a search query.'; status.className = 'status error'; return; }
  status.textContent = 'Searching Unsplash & Pexels...'; status.className = 'status';
  grid.innerHTML = '';

  try {
    const resp = await fetch(`${PROXY_URL}/api/search?query=${encodeURIComponent(q)}`);
    const data = await resp.json();
    if (!resp.ok) { status.textContent = `Error: ${data.error || resp.status}`; status.className = 'status error'; return; }
    if (!data.results?.length) { status.textContent = 'No results found.'; return; }
    status.textContent = `${data.results.length} results — tap to select`;
    status.className = 'status ok';
    data.results.forEach(item => {
      if (!item.preview) return;
      const div = document.createElement('div');
      div.className = 'thumb';
      const img = document.createElement('img');
      img.src = item.preview; img.loading = 'lazy'; img.alt = item.description || '';
      div.appendChild(img);
      const badge = document.createElement('span');
      badge.className = 'thumb-source ' + (item.source || '').toLowerCase();
      badge.textContent = item.source || '';
      div.appendChild(badge);
      div.onclick = async () => {
        document.querySelectorAll('.thumb').forEach(t => t.classList.remove('selected'));
        div.classList.add('selected');
        photoImg = await loadImage(item.preview);
        feat.scale = 1; feat.ox = 0; feat.oy = 0; featSyncUI();
        drawAll();
        // Auto-close sidebar on mobile after selecting image
        if (window.innerWidth <= 900) closeSidebar();
      };
      grid.appendChild(div);
    });
  } catch {
    status.textContent = `Cannot reach proxy. Is it running at ${PROXY_URL}?`;
    status.className = 'status error';
  }
}

// ─── Upload ────────────────────────────────────────────────────────────────
function handleUpload(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = async ev => {
    photoImg = await loadImage(ev.target.result);
    feat.scale = 1; feat.ox = 0; feat.oy = 0; featSyncUI();
    drawAll();
    if (window.innerWidth <= 900) closeSidebar();
  };
  reader.readAsDataURL(file);
}

// ─── Download ──────────────────────────────────────────────────────────────
function dl(id, filename) {
  const a = document.createElement('a');
  a.download = filename;
  a.href = document.getElementById(id).toDataURL('image/png');
  a.click();
}

// ─── Mobile sidebar toggle ─────────────────────────────────────────────────
function toggleSidebar() {
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('overlay');
  const isOpen  = sidebar.classList.contains('open');
  isOpen ? closeSidebar() : openSidebar();
}

function openSidebar() {
  document.getElementById('sidebar').classList.add('open');
  document.getElementById('overlay').classList.add('visible');
  document.body.style.overflow = 'hidden';
}

function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('visible');
  document.body.style.overflow = '';
}

// Close sidebar on Escape key
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeSidebar(); });

// ─── Boot ──────────────────────────────────────────────────────────────────
document.getElementById('headline').addEventListener('input', drawPreview);
document.getElementById('search-q').addEventListener('keydown', e => { if (e.key === 'Enter') searchImages(); });

setupCanvases();
loadLogoImage().then(drawAll);
</script>
</body>
</html>
