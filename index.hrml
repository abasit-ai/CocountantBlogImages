<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>CoCountant — Blog Preview Generator</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:         #0b1624;
    --surface:    #112036;
    --surface2:   #162840;
    --border:     rgba(255,255,255,0.08);
    --border-hi:  rgba(255,255,255,0.16);
    --text:       #f0f4f8;
    --text-muted: #7a9bb8;
    --text-dim:   #4a6a88;
    --accent:     #2B8CEE;
    --success:    #22c55e;
    --error:      #f87171;
    --radius:     10px;
    --radius-sm:  6px;
  }

  html, body { height: 100%; }

  body {
    font-family: 'Outfit', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── Header ── */
  header {
    flex-shrink: 0;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 20px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  header h1 {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-muted);
  }

  /* Mobile sidebar toggle button */
  .menu-btn {
    display: none;
    background: transparent;
    border: 1px solid var(--border-hi);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    font-size: 18px;
    width: 36px;
    height: 36px;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* ── Layout ── */
  .main {
    flex: 1;
    display: grid;
    grid-template-columns: 300px 1fr;
    min-height: 0;
    overflow: hidden;
  }

  /* ── Sidebar ── */
  .sidebar {
    background: var(--surface);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .section-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 10px;
  }

  /* ── Form elements ── */
  textarea, input[type="text"] {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    padding: 9px 12px;
    outline: none;
    transition: border-color 0.15s;
    line-height: 1.5;
    -webkit-appearance: none;
  }
  textarea { min-height: 80px; resize: vertical; }
  textarea:focus, input[type="text"]:focus { border-color: var(--accent); }
  ::placeholder { color: var(--text-dim); }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 16px;
    border-radius: var(--radius-sm);
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    border: none;
    white-space: nowrap;
    transition: opacity 0.15s, transform 0.1s;
    -webkit-tap-highlight-color: transparent;
  }
  .btn:active { transform: scale(0.97); }
  .btn-primary { background: var(--accent); color: #fff; }
  .btn-primary:hover { opacity: 0.85; }
  .btn-outline { background: transparent; border: 1px solid var(--border-hi); color: var(--text); }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }
  .btn-full { width: 100%; }

  .search-row { display: flex; gap: 8px; }
  .search-row input { flex: 1; min-width: 0; }

  .status { font-size: 12px; color: var(--text-muted); min-height: 18px; padding: 4px 0; }
  .status.error { color: var(--error); }
  .status.ok    { color: var(--success); }

  /* ── Source badges (sidebar) ── */
  .source-badges {
    display: flex;
    gap: 6px;
    margin-top: 6px;
    flex-wrap: wrap;
    align-items: center;
  }
  .source-badge {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
    letter-spacing: 0.04em;
  }
  .source-badge.unsplash { background: rgba(255,255,255,0.08); color: #e0e0e0; }
  .source-badge.pexels   { background: rgba(5,187,117,0.15);  color: #05bb75; }

  /* ── Results grid ── */
  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }

  .thumb {
    cursor: pointer;
    border-radius: 4px;
    overflow: hidden;
    border: 2px solid transparent;
    aspect-ratio: 4/3;
    background: var(--surface2);
    transition: border-color 0.15s;
    position: relative;
    -webkit-tap-highlight-color: transparent;
  }
  .thumb:hover  { border-color: var(--border-hi); }
  .thumb.selected { border-color: var(--accent); }
  .thumb.selected::after {
    content: '✓';
    position: absolute;
    top: 3px; right: 4px;
    background: var(--accent);
    color: #fff;
    font-size: 9px;
    width: 16px; height: 16px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700;
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .thumb-source {
    position: absolute;
    bottom: 3px; left: 4px;
    font-size: 8px;
    font-weight: 600;
    padding: 1px 5px;
    border-radius: 3px;
    letter-spacing: 0.03em;
    opacity: 0.85;
  }
  .thumb-source.unsplash { background: rgba(0,0,0,0.55); color: #fff; }
  .thumb-source.pexels   { background: rgba(5,187,117,0.8); color: #fff; }

  /* ── Content ── */
  .content {
    overflow-y: auto;
    padding: 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* ── Canvas card ── */
  .canvas-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
    gap: 8px;
    flex-wrap: wrap;
  }
  .canvas-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .badge {
    background: rgba(43,140,238,0.15);
    color: var(--accent);
    font-size: 11px;
    font-weight: 600;
    padding: 2px 9px;
    border-radius: 20px;
    white-space: nowrap;
  }
  .canvas-meta span { font-size: 12px; color: var(--text-dim); }

  .canvas-wrap {
    width: 100%;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: #102138;
    line-height: 0;
  }
  .canvas-wrap canvas {
    display: block;
    width: 100%;
    height: auto;
  }
  .canvas-wrap.interactive { cursor: grab; }
  .canvas-wrap.interactive:active { cursor: grabbing; }
  .canvas-wrap.fixed-width {
    display: inline-block;
    width: 416px;
    max-width: 100%;
  }

  /* ── Featured controls ── */
  .feat-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .feat-controls .zoom-label {
    font-size: 12px;
    color: var(--text-muted);
    min-width: 40px;
  }
  .feat-controls input[type="range"] {
    flex: 1;
    min-width: 60px;
    accent-color: var(--accent);
    cursor: pointer;
  }

  /* ── Scrollbar ── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  /* ════════════════════════════════════════
     TABLET  ≤ 900px — sidebar becomes a drawer
  ════════════════════════════════════════ */
  @media (max-width: 900px) {
    .main {
      grid-template-columns: 1fr;
      overflow: visible;
    }

    .menu-btn { display: inline-flex; }

    .sidebar {
      position: fixed;
      top: 52px;
      left: 0;
      width: 300px;
      max-width: 88vw;
      height: calc(100vh - 52px);
      z-index: 200;
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      border-right: 1px solid var(--border-hi);
      box-shadow: 4px 0 24px rgba(0,0,0,0.4);
    }

    .sidebar.open { transform: translateX(0); }

    /* Overlay behind the sidebar */
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 52px 0 0 0;
      background: rgba(0,0,0,0.5);
      z-index: 199;
    }
    .sidebar-overlay.visible { display: block; }

    .content {
      padding: 16px;
    }
  }

  /* ════════════════════════════════════════
     MOBILE  ≤ 480px
  ════════════════════════════════════════ */
  @media (max-width: 480px) {
    header { padding: 0 14px; }
    header h1 { font-size: 13px; }

    .content { padding: 12px; gap: 20px; }

    .canvas-header { gap: 6px; }
    .canvas-header .btn { padding: 7px 11px; font-size: 12px; }

    .badge { font-size: 10px; padding: 2px 7px; }

    /* On small screens, stack header row so download button doesn't overflow */
    .canvas-header { flex-direction: column; align-items: flex-start; }
    .canvas-header > div:last-child { width: 100%; }
    .canvas-header > button:last-child,
    .canvas-header > div:last-child .btn { width: 100%; }

    .feat-controls { gap: 6px; }
    .feat-controls .btn { padding: 7px 10px; font-size: 12px; }

    .results-grid { grid-template-columns: repeat(3, 1fr); gap: 5px; }
  }
</style>
</head>
<body>

<header>
  <h1>Blog Preview Generator</h1>
  <button class="menu-btn" onclick="toggleSidebar()" aria-label="Toggle menu">☰</button>
</header>

<!-- Overlay for mobile sidebar -->
<div class="sidebar-overlay" id="overlay" onclick="closeSidebar()"></div>

<div class="main">

  <aside class="sidebar" id="sidebar">

    <div>
      <div class="section-label">Blog Headline</div>
      <textarea id="headline" placeholder="Enter your blog post headline...">How can a business choose the right outsourced bookkeeping provider?</textarea>
    </div>

    <div>
      <div class="section-label">Upload Image</div>
      <label for="upload-img" class="btn btn-outline btn-full" style="cursor:pointer;">
        Upload local image
      </label>
      <input type="file" id="upload-img" accept="image/*" style="display:none;" onchange="handleUpload(event)" />
    </div>

    <div>
      <div class="section-label">Search Free Images</div>
      <div class="search-row">
        <input type="text" id="search-q" placeholder="e.g. business woman laptop" />
        <button class="btn btn-primary" onclick="searchImages()">Search</button>
      </div>
      <div class="source-badges">
        <span class="source-badge unsplash">Unsplash</span>
        <span class="source-badge pexels">Pexels</span>
        <span style="font-size:11px;color:var(--text-dim);">Free to use</span>
      </div>
      <div class="status" id="search-status"></div>
      <div class="results-grid" id="results"></div>
    </div>

  </aside>

  <div class="content">

    <!-- Blog Preview 1200×628 -->
    <div>
      <div class="canvas-header">
        <div class="canvas-meta">
          <span class="badge">1200 × 628 px</span>
          <span>Blog preview image</span>
        </div>
        <div style="display:flex;gap:8px;">
          <button class="btn btn-outline" onclick="drawAll()">Refresh</button>
          <button class="btn btn-primary" onclick="dl('c-preview','cocountant-blog-preview.png')">Download PNG</button>
        </div>
      </div>
      <div class="canvas-wrap">
        <canvas id="c-preview"></canvas>
      </div>
    </div>

    <!-- Featured 810×267 -->
    <div>
      <div class="canvas-header">
        <div class="canvas-meta">
          <span class="badge">810 × 267 px</span>
          <span>Featured image — photo only</span>
        </div>
        <button class="btn btn-primary" onclick="dl('c-featured','cocountant-featured.png')">Download PNG</button>
      </div>
      <div class="canvas-wrap interactive" id="feat-wrap">
        <canvas id="c-featured"></canvas>
      </div>
      <div class="feat-controls">
        <span class="zoom-label" id="feat-zoom-label">100%</span>
        <button class="btn btn-outline" style="padding:6px 10px;font-size:13px;" onclick="featZoom(-0.1)">−</button>
        <input type="range" id="feat-zoom-slider" min="50" max="300" value="100" step="1" oninput="featZoomSlider(this.value)" />
        <button class="btn btn-outline" style="padding:6px 10px;font-size:13px;" onclick="featZoom(0.1)">+</button>
        <button class="btn btn-outline" style="padding:6px 12px;font-size:12px;" onclick="featReset()">Reset</button>
      </div>
      <p style="font-size:11px;color:var(--text-dim);margin-top:6px;">Drag to pan · Scroll to zoom</p>
    </div>

    <!-- Thumbnail 416×332 -->
    <div>
      <div class="canvas-header">
        <div class="canvas-meta">
          <span class="badge">416 × 332 px</span>
          <span>Thumbnail image — photo only</span>
        </div>
        <button class="btn btn-primary" onclick="dl('c-thumbnail','cocountant-thumbnail.png')">Download PNG</button>
      </div>
      <div class="canvas-wrap fixed-width">
        <canvas id="c-thumbnail"></canvas>
      </div>
    </div>

  </div>
</div>

<script>
// ─── Config ────────────────────────────────────────────────────────────────
const PROXY_URL = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
  ? 'http://localhost:3000'
  : '';

// ─── Canvas setup ──────────────────────────────────────────────────────────
const DPR = 2;
const BG  = '#102138';
const PAD = 64;

const PH_W = 416, PH_H = 332;
const PH_X = 1200 - PAD - PH_W;
const PH_Y = Math.round((628 - PH_H) / 2);

let logoImg  = null;
let photoImg = null;

const SPECS = [
  { id: 'c-preview',   w: 1200, h: 628 },
  { id: 'c-featured',  w: 810,  h: 267 },
  { id: 'c-thumbnail', w: 416,  h: 332 },
];

const CTX = {};

function setupCanvases() {
  SPECS.forEach(({ id, w, h }) => {
    const el = document.getElementById(id);
    el.width  = w * DPR;
    el.height = h * DPR;
    el.style.aspectRatio = w + ' / ' + h;
    const ctx = el.getContext('2d');
    ctx.scale(DPR, DPR);
    ctx.imageSmoothingEnabled = true;
    ctx.imageSmoothingQuality = 'high';
    CTX[id] = ctx;
  });
}

function clear(id) {
  const s = SPECS.find(c => c.id === id);
  CTX[id].clearRect(0, 0, s.w, s.h);
}

function coverDraw(ctx, img, x, y, w, h) {
  const iw = img.naturalWidth  || img.width;
  const ih = img.naturalHeight || img.height;
  const sc = Math.max(w / iw, h / ih);
  const dw = iw * sc, dh = ih * sc;
  ctx.save();
  ctx.beginPath();
  ctx.rect(x, y, w, h);
  ctx.clip();
  ctx.drawImage(img, x + (w - dw) / 2, y + (h - dh) / 2, dw, dh);
  ctx.restore();
}

function placeholder(ctx, x, y, w, h) {
  ctx.save();
  ctx.fillStyle = 'rgba(255,255,255,0.05)';
  ctx.fillRect(x, y, w, h);
  ctx.strokeStyle = 'rgba(255,255,255,0.13)';
  ctx.lineWidth = 1;
  ctx.strokeRect(x + 0.5, y + 0.5, w - 1, h - 1);
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.font = '15px "Outfit",sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText('Search or upload an image to place here', x + w / 2, y + h / 2);
  ctx.restore();
}

function wrapText(ctx, text, x, maxW, cy, lh) {
  const words = text.split(' ');
  let line = '', lines = [];
  for (const w of words) {
    const t = line ? line + ' ' + w : w;
    if (ctx.measureText(t).width > maxW && line) { lines.push(line); line = w; }
    else line = t;
  }
  if (line) lines.push(line);
  const sy = cy - (lines.length * lh) / 2 + lh * 0.78;
  lines.forEach((l, i) => ctx.fillText(l, x, sy + i * lh));
}

// ─── Draw ──────────────────────────────────────────────────────────────────

function drawAll() { drawPreview(); drawFeatured(); drawThumbnail(); }

function drawPreview() {
  const id = 'c-preview', w = 1200, h = 628, ctx = CTX[id];
  const headline = document.getElementById('headline').value.trim() || 'Your headline here';
  clear(id);
  ctx.fillStyle = BG;
  ctx.fillRect(0, 0, w, h);
  if (logoImg) {
    const lh = 40, lw = Math.round((329 / 64) * lh);
    ctx.drawImage(logoImg, PAD, 42, lw, lh);
  }
  const fs = headline.length > 90 ? 40 : headline.length > 65 ? 46 : 52;
  ctx.save();
  ctx.fillStyle = '#ffffff';
  ctx.font = '500 ' + fs + 'px "Outfit",sans-serif';
  wrapText(ctx, headline, PAD, PH_X - PAD - 48, h / 2 + 14, fs * 1.28);
  ctx.restore();
  if (photoImg) coverDraw(ctx, photoImg, PH_X, PH_Y, PH_W, PH_H);
  else placeholder(ctx, PH_X, PH_Y, PH_W, PH_H);
}

// ─── Featured transform state ──────────────────────────────────────────────
const feat = { scale: 1, ox: 0, oy: 0 };
const FEAT_W = 810, FEAT_H = 267;

function featBaseScale() {
  if (!photoImg) return 1;
  const iw = photoImg.naturalWidth  || photoImg.width;
  const ih = photoImg.naturalHeight || photoImg.height;
  return Math.max(FEAT_W / iw, FEAT_H / ih);
}

function drawFeatured() {
  const id = 'c-featured', ctx = CTX[id];
  clear(id);
  if (!photoImg) { placeholder(ctx, 0, 0, FEAT_W, FEAT_H); return; }
  const base = featBaseScale();
  const sc = base * feat.scale;
  const iw = photoImg.naturalWidth  || photoImg.width;
  const ih = photoImg.naturalHeight || photoImg.height;
  const dw = iw * sc, dh = ih * sc;
  const dx = (FEAT_W - dw) / 2 + feat.ox;
  const dy = (FEAT_H - dh) / 2 + feat.oy;
  ctx.save();
  ctx.beginPath();
  ctx.rect(0, 0, FEAT_W, FEAT_H);
  ctx.clip();
  ctx.drawImage(photoImg, dx, dy, dw, dh);
  ctx.restore();
}

function featSyncUI() {
  const pct = Math.round(feat.scale * 100);
  document.getElementById('feat-zoom-label').textContent = pct + '%';
  document.getElementById('feat-zoom-slider').value = pct;
}

function featZoom(delta) {
  feat.scale = Math.min(3, Math.max(0.5, feat.scale + delta));
  featSyncUI(); drawFeatured();
}

function featZoomSlider(val) {
  feat.scale = parseFloat(val) / 100;
  featSyncUI(); drawFeatured();
}

function featReset() {
  feat.scale = 1; feat.ox = 0; feat.oy = 0;
  featSyncUI(); drawFeatured();
}

function drawThumbnail() {
  const id = 'c-thumbnail', w = 416, h = 332, ctx = CTX[id];
  clear(id);
  if (photoImg) coverDraw(ctx, photoImg, 0, 0, w, h);
  else placeholder(ctx, 0, 0, w, h);
}

// ─── Featured drag/pan/zoom interactions ──────────────────────────────────
(function () {
  let dragging = false, lastX = 0, lastY = 0;

  function toLogical(e, canvas) {
    const rect = canvas.getBoundingClientRect();
    return {
      x: (e.clientX - rect.left) * (FEAT_W / rect.width),
      y: (e.clientY - rect.top)  * (FEAT_H / rect.height),
    };
  }

  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById('c-featured');

    canvas.addEventListener('mousedown', e => {
      dragging = true;
      const p = toLogical(e, canvas);
      lastX = p.x; lastY = p.y;
      e.preventDefault();
    });

    window.addEventListener('mousemove', e => {
      if (!dragging) return;
      const c = document.getElementById('c-featured');
      const p = toLogical(e, c);
      feat.ox += p.x - lastX;
      feat.oy += p.y - lastY;
      lastX = p.x; lastY = p.y;
      drawFeatured();
    });

    window.addEventListener('mouseup', () => { dragging = false; });

    canvas.addEventListener('wheel', e => {
      e.preventDefault();
      featZoom(e.deltaY > 0 ? -0.05 : 0.05);
    }, { passive: false });

    // Touch drag
    let ltx = 0, lty = 0, lastDist = 0;
    canvas.addEventListener('touchstart', e => {
      if (e.touches.length === 1) {
        const rect = canvas.getBoundingClientRect();
        ltx = (e.touches[0].clientX - rect.left) * (FEAT_W / rect.width);
        lty = (e.touches[0].clientY - rect.top)  * (FEAT_H / rect.height);
      }
      if (e.touches.length === 2) {
        const dx = e.touches[0].clientX - e.touches[1].clientX;
        const dy = e.touches[0].clientY - e.touches[1].clientY;
        lastDist = Math.hypot(dx, dy);
      }
    }, { passive: true });

    canvas.addEventListener('touchmove', e => {
      if (e.touches.length === 1) {
        const rect = canvas.getBoundingClientRect();
        const tx = (e.touches[0].clientX - rect.left) * (FEAT_W / rect.width);
        const ty = (e.touches[0].clientY - rect.top)  * (FEAT_H / rect.height);
        feat.ox += tx - ltx;
        feat.oy += ty - lty;
        ltx = tx; lty = ty;
        drawFeatured();
        e.preventDefault();
      }
      // Pinch to zoom
      if (e.touches.length === 2) {
        const dx = e.touches[0].clientX - e.touches[1].clientX;
        const dy = e.touches[0].clientY - e.touches[1].clientY;
        const dist = Math.hypot(dx, dy);
        const delta = (dist - lastDist) * 0.005;
        featZoom(delta);
        lastDist = dist;
        e.preventDefault();
      }
    }, { passive: false });
  });
}());

// ─── Logo ──────────────────────────────────────────────────────────────────
